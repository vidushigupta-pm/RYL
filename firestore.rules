rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: /products/{productId}
    // Fields:
    //   - product_name: string (required)
    //   - brand: string (optional)
    //   - category: string (required)
    //   - ingredients: list (required)
    //   - nutrition: map (optional)
    //   - overall_score: number (required)
    //   - score_breakdown: map (required)
    //   - summary: string (required)
    //   - india_context: string (required)
    //   - is_upf: bool (required)
    //   - hfss_status: string (required)
    //   - suggestions: list (required)
    //   - last_updated: timestamp (required)
    //
    // Collection: /ingredients/{ingredientId}
    // Fields:
    //   - name: string (required)
    //   - common_names: list (required)
    //   - function: string (required)
    //   - safety_tier: string (required, GREEN/YELLOW/ORANGE/RED)
    //   - plain_explanation: string (required)
    //   - condition_flags: list (required)
    //   - india_specific_note: string (optional)
    //   - score_impact: number (required)
    //   - data_quality: string (required, VERIFIED/LLM_GENERATED)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "vidushi2904@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidProduct(data) {
      return hasRequiredFields(['product_name', 'category', 'ingredients', 'overall_score', 'summary', 'last_updated']) &&
             data.product_name is string && data.product_name.size() < 200 &&
             data.category is string &&
             data.ingredients is list && data.ingredients.size() < 100 &&
             data.overall_score is number &&
             data.summary is string && data.summary.size() < 2000 &&
             data.last_updated is timestamp;
    }

    function isValidIngredient(data) {
      return hasRequiredFields(['name', 'safety_tier', 'function', 'plain_explanation', 'score_impact', 'data_quality']) &&
             data.name is string && data.name.size() < 100 &&
             data.safety_tier in ['GREEN', 'YELLOW', 'ORANGE', 'RED'] &&
             data.function is string && data.function.size() < 500 &&
             data.plain_explanation is string && data.plain_explanation.size() < 1000 &&
             data.score_impact is number &&
             data.data_quality in ['VERIFIED', 'LLM_GENERATED'];
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /products/{productId} {
      // Allow anyone to read products (publicly available info)
      allow read: if true;
      // Only authenticated users can contribute new products
      allow create: if isAuthenticated() && isValidProduct(request.resource.data);
      // Only admins can update or delete products
      allow update, delete: if isAdmin();
    }

    match /ingredients/{ingredientId} {
      // Allow anyone to read ingredient details
      allow read: if true;
      // Only authenticated users can contribute new ingredient data (LLM_GENERATED)
      allow create: if isAuthenticated() && isValidIngredient(request.resource.data);
      // Only admins can update or delete ingredients (to verify LLM data)
      allow update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow create: if isAuthenticated() && request.auth.uid == userId && 
                    hasOnlyAllowedFields(['role', 'email', 'name']) &&
                    request.resource.data.role == 'user';
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
