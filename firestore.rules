rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: /products/{productId}
    // Fields:
    //   - product_name: string (required)
    //   - category: string (required)
    //   - cached_verdict: map (required) — full analysis result JSON
    //   - verdict_computed_at: timestamp (required)
    //   - brand: string (optional)
    //   - ingredients_list: list (optional)
    //   - nutrition: map (optional)
    //   - name_aliases: list (optional)
    //   - data_source: string (optional)
    //   - needs_reverification: bool (optional)
    //
    // Collection: /ingredients/{ingredientId}
    // Fields:
    //   - name: string (required)
    //   - safety_tier: string (required, SAFE/CAUTION/AVOID/BANNED_IN_INDIA/UNVERIFIED)
    //   - function: string (required)
    //   - plain_explanation: string (required)
    //   - score_impact: number (required)
    //   - data_quality: string (required, VERIFIED/LLM_GENERATED)
    //   - common_names: list (optional)
    //   - condition_flags: list (optional)
    //   - india_specific_note: string (optional)
    //
    // Collection: /users/{userId}/profiles/{profileId}
    // Collection: /users/{userId}/scans/{scanId}
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "vidushi2904@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidProduct(data) {
      return hasRequiredFields(['product_name', 'category', 'cached_verdict', 'verdict_computed_at']) &&
             data.product_name is string && data.product_name.size() < 200 &&
             data.category is string &&
             data.cached_verdict is map &&
             data.verdict_computed_at is timestamp;
    }

    function isValidIngredient(data) {
      return hasRequiredFields(['name', 'safety_tier', 'function', 'plain_explanation', 'score_impact', 'data_quality']) &&
             data.name is string && data.name.size() < 100 &&
             data.safety_tier in ['SAFE', 'CAUTION', 'AVOID', 'BANNED_IN_INDIA', 'UNVERIFIED'] &&
             data.function is string && data.function.size() < 500 &&
             data.plain_explanation is string && data.plain_explanation.size() < 1000 &&
             data.score_impact is number &&
             data.data_quality in ['VERIFIED', 'LLM_GENERATED'];
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /products/{productId} {
      // Public read — product safety data is not personal
      allow read: if true;
      // Authenticated users can create or update products (upsert via merge: true)
      allow create, update: if isAuthenticated() && isValidProduct(request.resource.data);
      // Only admins can delete products
      allow delete: if isAdmin();
    }

    match /ingredients/{ingredientId} {
      // Public read — ingredient data is not personal
      allow read: if true;
      // Authenticated users can create or update ingredient records
      allow create, update: if isAuthenticated() && isValidIngredient(request.resource.data);
      // Only admins can delete ingredients
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow create: if isAuthenticated() && request.auth.uid == userId &&
                    request.resource.data.keys().hasOnly(['role', 'email', 'name']) &&
                    request.resource.data.role == 'user';
      // Users can update their own document; admins can update anyone's
      allow update: if (isAuthenticated() && request.auth.uid == userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /users/{userId}/profiles/{profileId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    match /users/{userId}/scans/{scanId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }
  }
}
