# Copy this file to scripts/.env and fill in the values to run the seed script.
# NEVER commit scripts/.env — it contains your private service account key.

# Get from: Firebase Console → Project Settings → Service Accounts → Generate New Private Key
# Then base64-encode it:
#   On Mac/Linux: base64 -i service-account.json
#   On Windows PowerShell: [Convert]::ToBase64String([IO.File]::ReadAllBytes("service-account.json"))
FIREBASE_SERVICE_ACCOUNT_BASE64=your_base64_service_account_json_here

# Your named Firestore database ID (from firebase-applet-config.json)
FIRESTORE_DB_ID=ai-studio-0f7174ae-7a98-4951-8d4f-e23ec80681da
