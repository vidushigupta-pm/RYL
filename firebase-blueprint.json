{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A scanned or searched product with its analysis.",
      "type": "object",
      "properties": {
        "product_name": { "type": "string" },
        "brand": { "type": "string" },
        "category": { "type": "string" },
        "ingredients": { "type": "array", "items": { "type": "string" } },
        "nutrition": { "type": "object" },
        "overall_score": { "type": "number" },
        "score_breakdown": { "type": "object" },
        "summary": { "type": "string" },
        "india_context": { "type": "string" },
        "is_upf": { "type": "boolean" },
        "hfss_status": { "type": "string" },
        "suggestions": { "type": "array", "items": { "type": "string" } },
        "last_updated": { "type": "string", "format": "date-time" }
      },
      "required": ["product_name", "category", "ingredients"]
    },
    "Ingredient": {
      "title": "Ingredient",
      "description": "A verified ingredient with its safety and function details.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "common_names": { "type": "array", "items": { "type": "string" } },
        "function": { "type": "string" },
        "safety_tier": { "type": "string", "enum": ["GREEN", "YELLOW", "ORANGE", "RED"] },
        "plain_explanation": { "type": "string" },
        "condition_flags": { "type": "array", "items": { "type": "object" } },
        "india_specific_note": { "type": "string" },
        "score_impact": { "type": "number" },
        "data_quality": { "type": "string", "enum": ["VERIFIED", "LLM_GENERATED"] }
      },
      "required": ["name", "safety_tier", "function"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of analyzed products."
    },
    "/ingredients/{ingredientId}": {
      "schema": "Ingredient",
      "description": "Global registry of ingredients and their safety details."
    }
  }
}
